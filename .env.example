# ============================================================================
# ENVIRONMENT & DEPLOYMENT
# ============================================================================
ENVIRONMENT=development
LOG_LEVEL=DEBUG
API_HOST=0.0.0.0
API_PORT=8000
DASHBOARD_PORT=8501

# ============================================================================
# OPENAI / LANGUAGE MODEL
# ============================================================================
OPENAI_API_KEY=sk-...
OPENAI_ORG_ID=org-...
OPENAI_MODEL=gpt-4o
OPENAI_MODEL_VISION=gpt-4-vision-preview
MAX_TOKENS_PER_REQUEST=4000
TEMPERATURE=0.7

# ============================================================================
# SUPABASE (DATABASE & AUTH)
# ============================================================================
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_KEY=your-supabase-anon-key
SUPABASE_SERVICE_KEY=your-supabase-service-role-key
DATABASE_URL=postgresql://postgres:password@localhost:5432/agente_ia

# ============================================================================
# REDIS (CACHING & MESSAGE BUFFER)
# ============================================================================
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=
REDIS_DB=0
BUFFER_DELAY_SECONDS=3

# ============================================================================
# META CLOUD API (WHATSAPP, INSTAGRAM, FACEBOOK)
# ============================================================================
# These are YOUR credentials (shared across all clients)
META_VERIFY_TOKEN=your_random_verify_token_string
META_ACCESS_TOKEN=your-meta-long-lived-access-token
META_BUSINESS_ACCOUNT_ID=123456789
META_API_VERSION=v18.0

# Webhook validation
META_WEBHOOK_VERIFY_TOKEN=your_random_verify_token_string

# ============================================================================
# STRIPE (MY BILLING - Client Subscriptions)
# ============================================================================
STRIPE_SECRET_KEY=sk_live_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_live_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_PRODUCT_ID=prod_your_product_id

# Pre-configured Price IDs per plan (avoids creating a new price for each client)
# Create these once in Stripe Dashboard → Products → Add price (recurring, monthly)
STRIPE_PRICE_BASICO=price_your_basico_149_monthly
STRIPE_PRICE_PROFESIONAL=price_your_profesional_249_monthly
STRIPE_PRICE_EMPRESARIAL=price_your_empresarial_399_monthly

# Shared secret for server-to-server calls from the Next.js dashboard to the backend
# Generate with: openssl rand -hex 32
INTERNAL_API_SECRET=your_random_internal_secret_here

# ============================================================================
# SENDGRID (EMAIL OUTBOUND & INBOUND)
# ============================================================================
SENDGRID_API_KEY=SG.your_sendgrid_api_key
SENDGRID_FROM_EMAIL=noreply@agente-ia.com
SENDGRID_INBOUND_WEBHOOK_SECRET=your_webhook_secret

# ============================================================================
# GOOGLE CALENDAR (BOOKING INTEGRATION)
# ============================================================================
# Base64-encoded service account JSON credentials
GOOGLE_CALENDAR_CREDENTIALS_JSON=base64-encoded-service-account-json
GOOGLE_CALENDAR_TIMEZONE=America/Guayaquil

# ============================================================================
# JWT & SECURITY
# ============================================================================
JWT_SECRET_KEY=your-super-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24
ENCRYPTION_KEY=your-encryption-key-32-bytes-min

# ============================================================================
# RATE LIMITING
# ============================================================================
RATE_LIMIT_PER_USER_PER_MINUTE=30
RATE_LIMIT_PER_CLIENT_PER_HOUR=10000
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=30

# ============================================================================
# BUSINESS LOGIC CONFIGURATION
# ============================================================================
# Default module toggles (can be overridden per client)
MODULES_VENTAS_ENABLED=true
MODULES_AGENDAMIENTO_ENABLED=true
MODULES_COBROS_ENABLED=true
MODULES_LINKS_PAGO_ENABLED=true
MODULES_CALIFICACION_ENABLED=true
MODULES_CAMPANAS_ENABLED=true
MODULES_ALERTAS_ENABLED=true
MODULES_SEGUIMIENTOS_ENABLED=true
MODULES_DOCUMENTOS_ENABLED=true

# Default business hours (can be overridden per client)
BUSINESS_HOURS_START=08:00
BUSINESS_HOURS_END=18:00
BUSINESS_TIMEZONE=America/Guayaquil

# Lead scoring thresholds
LEAD_SCORE_HOT_THRESHOLD=8
LEAD_SCORE_NOTIFICATION_ENABLED=true

# Payment verification
PAYMENT_VERIFICATION_ENABLED=true
PAYMENT_FRAUD_SCORE_THRESHOLD=0.7

# Typing indicator delay (ms)
TYPING_INDICATOR_DELAY_MS=1000

# ============================================================================
# MONITORING & LOGGING
# ============================================================================
SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
LOG_FORMAT=json

# ============================================================================
# DEVELOPMENT ONLY
# ============================================================================
# Set to true to skip webhook signature validation (NEVER in production)
SKIP_WEBHOOK_VALIDATION=false

# Test API keys (only used in test environment)
TEST_CLIENT_ID=test-client-123
TEST_USER_ID=test-user-456
TEST_OPENAI_API_KEY=sk-test-...

NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
JWT_SECRET=your-jwt-secret-min-32-chars-random
NEXT_PUBLIC_API_URL=https://api.yourdomain.com