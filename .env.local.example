# ============================================================================
# LOCAL DEVELOPMENT ONLY - Copy this to .env.local and fill in your values
# NEVER commit .env.local to git
# ============================================================================

# OPENAI
OPENAI_API_KEY=sk-proj-your-key-here
OPENAI_ORG_ID=org-your-id

# SUPABASE
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-key

# REDIS
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=your-password

# META
META_ACCESS_TOKEN=your-token
META_VERIFY_TOKEN=your-verify-token

# STRIPE
STRIPE_SECRET_KEY=sk_test_your-key
STRIPE_PUBLISHABLE_KEY=pk_test_your-key

# SENDGRID
SENDGRID_API_KEY=SG.your-key

# GOOGLE
GOOGLE_CALENDAR_CREDENTIALS_JSON=your-base64-json

# JWT
JWT_SECRET_KEY=your-secret-key-32-bytes-minimum
ENCRYPTION_KEY=your-encryption-key-32-bytes-minimum


