[flake8]
# Flake8 configuration for Agente-IA

# Line length
max-line-length = 100

# Ignore specific error codes
# E203: Whitespace before ':'
# W503: Line break before binary operator
# W504: Line break after binary operator
ignore = E203, W503, W504

# Exclude directories
exclude = .git,__pycache__,.venv,venv,build,dist,.eggs,*.egg

# Per-file-ignores
per-file-ignores =
    __init__.py:F401
    tests/*:F841,F401

# Complexity
max-complexity = 10

# Statistics
statistics = true

# Show source
show-source = true

# Count
count = true
